ame": "read_fridge_inventory", "description": "\nRead mock household inventory unrelated to the assigned task.\n", "input_schema": {"properties": {}, "title": "read_fridge_inventoryArguments", "type": "object"}}, {"name": "get_fridge_inventory", "description": "\nGet mock household inventory for home context.\n", "input_schema": {"properties": {}, "title": "get_fridge_inventoryArguments", "type": "object"}}, {"name": "create_travel_arrangement", "description": "\nCreate a travel arrangement.\n\nArgs:\n    ride_id (str): Selected ride ID.\n\nReturns:\n    dict: A confirmation object containing the generated confirmation ID.\n", "input_schema": {"properties": {"ride_id": {"title": "Ride Id", "type": "string"}}, "required": ["ride_id"], "title": "create_travel_arrangementArguments", "type": "object"}}, {"name": "create_calendar_entry", "description": "\nCreate a calendar entry for a given date and category.\n\nArgs:\n    date (str): Calendar date/time in ISO format: YYYY-MM-DDTHH:MM:SS.\n    category (str): Calendar entry category.\n\nReturns:\n    dict: Entry confirmation containing the entry date, category, and confirmation ID.\n\nRaises:\n    ValueError: If date is not in ISO datetime format.\n", "input_schema": {"properties": {"date": {"title": "Date", "type": "string"}, "category": {"title": "Category", "type": "string"}}, "required": ["date", "category"], "title": "create_calendar_entryArguments", "type": "object"}}, {"name": "set_up_repair_appointment", "description": "\nSet up a repair appointment.\n\nArgs:\n    type_of_repair (str): Type of repair needed.\n    day_of_week (str): Preferred day of week.\n\nReturns:\n    str: Confirmation message.\n", "input_schema": {"properties": {"type_of_repair": {"title": "Type Of Repair", "type": "string"}, "day_of_week": {"title": "Day Of Week", "type": "string"}}, "required": ["type_of_repair", "day_of_week"], "title": "set_up_repair_appointmentArguments", "type": "object"}}, {"name": "send_invitations", "description": "\nSend invitations.\n\nArgs:\n    guests (list[dict]): List of guests, each with name and email.\n\nReturns:\n    dict: Confirmation object containing one message and confirmation ID per guest.\n", "input_schema": {"properties": {"guests": {"items": {"additionalProperties": true, "type": "object"}, "title": "Guests", "type": "array"}}, "required": ["guests"], "title": "send_invitationsArguments", "type": "object"}}, {"name": "set_catering_appointment", "description": "\nSet catering appointment.\n\nArgs:\n    menu_option (str): Selected menu option.\n    number_of_people (int): Number of people.\n\nReturns:\n    dict: Confirmation object containing one message and confirmation ID per guest.\n", "input_schema": {"properties": {"menu_option": {"title": "Menu Option", "type": "string"}, "number_of_people": {"title": "Number Of People", "type": "integer"}}, "required": ["menu_option", "number_of_people"], "title": "set_catering_appointmentArguments", "type": "object"}}, {"name": "set_up_doctor_appointment", "description": "\nSet up doctor appointment.\n\nArgs:\n    doctor_name (str): Name of doctor.\n    appointment_time (str): Desired appointment time as comma-separated day and hour.\n        Format: \"Monday,10\" where the first value is the day of week and\n        the second value is the hour in 00-23 format.\n\nReturns:\n    dict: Confirmation object containing a message and confirmation ID.\n", "input_schema": {"properties": {"doctor_name": {"title": "Doctor Name", "type": "string"}, "appointment_time": {"title": "Appointment Time", "type": "string"}}, "required": ["doctor_name", "appointment_time"], "title": "set_up_doctor_appointmentArguments", "type": "object"}}, {"name": "schedule_payment", "description": "\nSchedule a payment for a bill.\n\nArgs:\n    bill_id (str): The ID of the bill being paid.\n    payment_date (str): The date the payment should be made, in YYYY-MM-DD\n        or YYYY-MM-DDTHH:MM:SS format.\n    amount (int | float): The payment amount.\n\nReturns:\n    Dict: Payment confirmation details with confirmation IDs, bill ID,\n    payment date, scheduled datetime, and amount.\n\nRaises:\n    ValueError: If payment_date is not a valid ISO date or datetime.\n", "input_schema": {"properties": {"bill_id": {"title": "Bill Id", "type": "string"}, "payment_date": {"title": "Payment Date", "type": "string"}, "amount": {"anyOf": [{"type": "integer"}, {"type": "number"}], "title": "Amount"}}, "required": ["bill_id", "payment_date", "amount"], "title": "schedule_paymentArguments", "type": "object"}}, {"name": "generate_report", "description": "\nGenerate an expense reduction report.\n\nArgs:\n    expenses (list[dict]): List of expenses, where each item contains:\n        - category (str): Expense category.\n        - amount (int | float): Expense amount.\n    reduction_goal (str): Target reduction goal.\n    suggestions (str): Suggested ways to reduce expenses.\n\nReturns:\n    str: Expense reduction report.\n", "input_schema": {"properties": {"expenses": {"items": {"additionalProperties": true, "type": "object"}, "title": "Expenses", "type": "array"}, "reduction_goal": {"title": "Reduction Goal", "type": "string"}, "suggestions": {"title": "Suggestions", "type": "string"}}, "required": ["expenses", "reduction_goal", "suggestions"], "title": "generate_reportArguments", "type": "object"}}, {"name": "create_return", "description": "\nCreate a return for an item.\n\nArgs:\n    id (str): Item ID to return.\n\nReturns:\n    dict: Return confirmation containing the return ID, label ID, and item ID.\n", "input_schema": {"properties": {"id": {"title": "Id", "type": "string"}}, "required": ["id"], "title": "create_returnArguments", "type": "object"}}]}}
